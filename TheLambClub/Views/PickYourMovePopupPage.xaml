<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="TheLambClub.Views.PickYourMovePopupPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:m="clr-namespace:TheLambClub.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:TheLambClub.ViewModel"
    x:DataType="vm:PickYourMovePopupPageVM"
    CanBeDismissedByTappingOutsideOfPopup="False">

    <Border Stroke="Gray" 
            StrokeThickness="1" 
            Padding="10" 
            Margin="5"
            WidthRequest="320"
            HeightRequest="450">

        <Grid ColumnDefinitions="1.3*, 1*" 
              RowDefinitions="Auto, Auto, Auto, *" 
              ColumnSpacing="10" 
              RowSpacing="15">

            <VerticalStackLayout
                Grid.Column="0"
                Grid.Row="0"
                Grid.ColumnSpan="2"
                Spacing="5"
                HorizontalOptions="Fill">
                <Label
                    FontSize="18"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    VerticalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    HeightRequest="60"
                    Text="{Binding BetAmountStr}" />
                <Slider
                    Maximum="{Binding MaxBet}"
                    Minimum="{Binding MinBet}"
                    HorizontalOptions="Fill"
                    Value="{Binding BetAmount}" />
            </VerticalStackLayout>

            <VerticalStackLayout
                Grid.Column="0"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                HorizontalOptions="Fill"
                VerticalOptions="Center">
                <Button 
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="15"
                    BackgroundColor="DarkBlue"
                    Command="{Binding SubmitBetCommand}" 
                    Text="{x:Static m:Strings.SubmitBetBtn}" />
            </VerticalStackLayout>

            <VerticalStackLayout
                Grid.Column="0"
                Grid.Row="2"
                Spacing="8"
                VerticalOptions="Start">
                <Button
                    BackgroundColor="DarkBlue"
                    Command="{Binding Stay}"
                    CornerRadius="15"
                    FontSize="16"
                    HeightRequest="60"
                    LineBreakMode="WordWrap"
                    Text="{Binding CheckOrFold}"
                    TextColor="White"
                    Padding="5"
                    HorizontalOptions="Fill" />
                <Button
                    BackgroundColor="DarkBlue"
                    Command="{Binding Fold}"
                    CornerRadius="15"
                    FontSize="18"
                    HeightRequest="50"
                    Text="{x:Static m:Strings.FoldBtnTxt}"
                    TextColor="White"
                    HorizontalOptions="Fill" />
            </VerticalStackLayout>

            <VerticalStackLayout
                Grid.Column="1"
                Grid.Row="2"
                Spacing="8"
                VerticalOptions="Start">
                <Button
                    BackgroundColor="DarkSlateGray"
                    Command="{Binding GetSuggestionCommand}"
                    CornerRadius="15"
                    FontSize="13"
                    HeightRequest="45"
                    IsEnabled="{Binding CanRequestSuggestion}"
                    Text="{x:Static m:Strings.GetAISuggestion}"
                    TextColor="White"
                    HorizontalOptions="Fill" />
                <Border Padding="2" BackgroundColor="Black" StrokeThickness="0">
                    <Label
                        x:Name="TimeLeft"
                        BackgroundColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HorizontalOptions="Fill"
                        HorizontalTextAlignment="Center"
                        Text="{Binding TimeLeft}"
                        VerticalOptions="Center" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="3"
                Padding="0,5"
                VerticalOptions="Center">
                <Label
                    FontSize="12"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding AiSuggestionVisible}"
                    Text="{Binding AiSuggestionText}"
                    LineBreakMode="WordWrap"
                    TextColor="Gray" />
                <ActivityIndicator
                    HorizontalOptions="Center"
                    IsRunning="{Binding IsLoadingSuggestion}"
                    IsVisible="{Binding IsLoadingSuggestion}"
                    Color="DarkBlue" />
            </VerticalStackLayout>
        </Grid>
    </Border>
</toolkit:Popup>